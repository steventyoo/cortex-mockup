jobs":61,"variance_orig_to_actual":{"n":61,"min":-0.3361,"max":1.0927,"mean":0.1186,"median":0.0544,"p25":-0.0983,"p50":0.0544,"p75":0.2517,"p10":-0.199,"p90":0.4873},"median_actual_dollars":255360.5},"implication":"Bid model should apply a +10\u201315% correction factor to rough-in labor takeoff specifically. Material cushion alone does not compensate for this \u2014 labor is harder to recover once underbid."},{"id":"hours_per_unit_house_standard","severity":"high","title":"House standard for labor productivity is ~118 hours per plumbing unit","value":117.5,"unit":"hours","summary":"Median is 117.5 hrs/unit (P25 100, P75 143). The middle 50% of jobs sit between 100 and 143 hrs/unit \u2014 that is the credible band for a like-for-like new bid.","evidence":{"n":61,"min":57.375,"max":354.3341,"mean":124.2147,"median":117.5,"p25":100.2083,"p50":117.5,"p75":142.7664,"p10":75.4898,"p90":159.5476,"note":"Total field hours / plumbing units","unit":"hours"},"implication":"Bids that fall below P25 or above P75 should be flagged for explicit justification \u2014 the bidding tool should not silently extrapolate beyond the historical band."},{"id":"gross_margin_band","severity":"medium","title":"Gross margin clusters at 38.2%","value":0.3818,"unit":"fraction","summary":"Median gross margin is 38.2%. This is what OWP earns once direct cost (labor + material + burden + tax) is removed from billed revenue.","evidence":{"n_jobs":61,"p25":0.3115,"median":0.3818,"p75":0.4544},"implication":"Use as default target margin. Combine with material-takeoff cushion finding for total margin posture."},{"id":"wage_burden","severity":"medium","title":"Fully loaded labor cost is ~$42.58/hr (1.42\u00d7 blended)","value":42.5787,"unit":"USD/hr","summary":"Median fully loaded wage (labor + burden) is $42.58/hr. Burden multiplier of 1.42\u00d7 means OWP carries ~42% on top of direct wages for taxes, insurance, vehicles, etc.","evidence":{"blended_wage_median":29.4969,"loaded_wage_median":42.5787,"burden_multiplier_median":1.421},"implication":"Always price labor at fully-loaded wage in the bid model."},{"id":"labor_variance_neutral","severity":"medium","title":"Labor variance is roughly balanced (-15.2% median)","value":-0.1517,"unit":"fraction","summary":"Unlike material (consistently under), labor variance from original budget to actual is closer to neutral (median -15.2%). The bid model should NOT assume a labor cushion the way it can for material.","evidence":{"n":584,"min":-0.9914,"max":3.4135,"mean":-0.0989,"median":-0.1517,"p25":-0.4053,"p50":-0.1517,"p75":0.093,"p10":-0.5936,"p90":0.3961},"implication":"Bid the labor number close to the takeoff \u2014 there is no systematic safety margin."}],"benchmarks":{"hours_per_unit":{"n":61,"min":57.375,"max":354.3341,"mean":124.2147,"median":117.5,"p25":100.2083,"p50":117.5,"p75":142.7664,"p10":75.4898,"p90":159.5476,"note":"Total field hours / plumbing units","unit":"hours"},"labor_dollars_per_unit":{"n":61,"min":1419.3979,"max":11628.9416,"mean":3699.4371,"median":3630.5968,"p25":2915.9517,"p50":3630.5968,"p75":4226.323,"p10":1994.5991,"p90":5200.5038,"note":"Direct labor cost / plumbing units","unit":"USD"},"material_dollars_per_unit":{"n":61,"min":1219.6971,"max":9672.2479,"mean":3761.7582,"median":3691.8947,"p25":2901.1926,"p50":3691.8947,"p75":4408.2127,"p10":2096.4142,"p90":5084.9389,"note":"200-series cost code spend / plumbing units","unit":"USD"},"revenue_per_unit":{"n":61,"min":7181.5,"max":41985.5421,"mean":15806.6212,"median":16111.1733,"p25":12652.0526,"p50":16111.1733,"p75":18371.32,"p10":10168.7458,"p90":20850.7944,"note":"999 sales code billed / plumbing units","unit":"USD"},"labor_pct_of_revenue":{"n":61,"min":0.1089,"max":0.3355,"mean":0.234,"median":0.227,"p25":0.2071,"p50":0.227,"p75":0.2689,"p10":0.1851,"p90":0.2887,"note":"Labor cost / revenue","unit":"fraction"},"material_pct_of_revenue":{"n":61,"min":0.0936,"max":0.3135,"mean":0.2375,"median":0.2358,"p25":0.2186,"p50":0.2358,"p75":0.2651