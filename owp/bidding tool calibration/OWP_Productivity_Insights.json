6504,"burden_multiplier_median":1.4284},"implication":"Always price labor at fully-loaded wage in the bid model."},{"id":"labor_variance_neutral","severity":"medium","title":"Labor variance is roughly balanced (-15.7% median)","value":-0.1565,"unit":"fraction","summary":"Unlike material (consistently under), labor variance from original budget to actual is closer to neutral (median -15.7%). The bid model should NOT assume a labor cushion the way it can for material.","evidence":{"n":492,"min":-0.9914,"max":3.4135,"mean":-0.0939,"median":-0.1565,"p25":-0.4139,"p50":-0.1565,"p75":0.0864,"p10":-0.5922,"p90":0.4313},"implication":"Bid the labor number close to the takeoff \u2014 there is no systematic safety margin."}],"benchmarks":{"hours_per_unit":{"n":52,"min":57.375,"max":2400.0,"mean":166.6661,"median":117.1266,"p25":99.7119,"p50":117.1266,"p75":142.7733,"p10":74.4469,"p90":164.5244,"note":"Total field hours / plumbing units","unit":"hours"},"labor_dollars_per_unit":{"n":52,"min":1419.3979,"max":90082.0,"mean":5197.8335,"median":3496.9671,"p25":2691.195,"p50":3496.9671,"p75":4132.3433,"p10":1933.7128,"p90":4533.1668,"note":"Direct labor cost / plumbing units","unit":"USD"},"material_dollars_per_unit":{"n":52,"min":1219.6971,"max":58415.81,"mean":4567.5374,"median":3403.2433,"p25":2802.5368,"p50":3403.2433,"p75":4108.1654,"p10":2033.8086,"p90":4651.5443,"note":"200-series cost code spend / plumbing units","unit":"USD"},"revenue_per_unit":{"n":52,"min":7181.5,"max":350295.0,"mean":21653.9543,"median":15636.3363,"p25":11838.9352,"p50":15636.3363,"p75":17319.8912,"p10":9930.1962,"p90":19167.099,"note":"999 sales code billed / plumbing units","unit":"USD"},"labor_pct_of_revenue":{"n":52,"min":0.1089,"max":0.3355,"mean":0.2325,"median":0.226,"p25":0.209,"p50":0.226,"p75":0.2654,"p10":0.1855,"p90":0.2835,"note":"Labor cost / revenue","unit":"fraction"},"material_pct_of_revenue":{"n":52,"min":0.0936,"max":0.3135,"mean":0.2305,"median":0.2329,"p25":0.2127,"p50":0.2329,"p75"