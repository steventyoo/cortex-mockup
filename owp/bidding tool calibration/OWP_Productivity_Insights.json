.9712,"burden_multiplier_median":1.4256},"implication":"Always price labor at fully-loaded wage in the bid model."},{"id":"labor_variance_neutral","severity":"medium","title":"Labor variance is roughly balanced (-15.5% median)","value":-0.155,"unit":"fraction","summary":"Unlike material (consistently under), labor variance from original budget to actual is closer to neutral (median -15.5%). The bid model should NOT assume a labor cushion the way it can for material.","evidence":{"n":512,"min":-0.9914,"max":3.4135,"mean":-0.0927,"median":-0.155,"p25":-0.411,"p50":-0.155,"p75":0.0987,"p10":-0.5888,"p90":0.4313},"implication":"Bid the labor number close to the takeoff \u2014 there is no systematic safety margin."}],"benchmarks":{"hours_per_unit":{"n":54,"min":57.375,"max":2400.0,"mean":165.3485,"median":117.4259,"p25":100.3106,"p50":117.4259,"p75":141.4763,"p10":74.6786,"p90":163.2289,"note":"Total field hours / plumbing units","unit":"hours"},"labor_dollars_per_unit":{"n":54,"min":1419.3979,"max":90082.0,"mean":5173.2679,"median":3554.1908,"p25":2702.0009,"p50":3554.1908,"p75":4155.7947,"p10":1947.2431,"p90":4756.4042,"note":"Direct labor cost / plumbing units","unit":"USD"},"material_dollars_per_unit":{"n":54,"min":1219.6971,"max":58415.81,"mean":4554.8018,"median":3459.5479,"p25":2823.3229,"p50":3459.5479,"p75":4126.1447,"p10":2047.7209,"p90":4724.9768,"note":"200-series cost code spend / plumbing units","unit":"USD"},"revenue_per_unit":{"n":54,"min":7181.5,"max":350295.0,"mean":21412.8219,"median":15636.3363,"p25":12063.6556,"p50":15636.3363,"p75":17235.2238,"p10":9983.2072,"p90":19148.297,"note":"999 sales code billed / plumbing units","unit":"USD"},"labor_pct_of_revenue":{"n":54,"min":0.1089,"max":0.3355,"mean":0.235,"median":0.2272,"p25":0.2099,"p50":0.2272,"p75":0.2715,"p10":0.1864,"p90":0.2874,"note":"Labor cost / revenue","unit":"fraction"},"material_pct_of_revenue":{"n":54,"min":0.0936,"max":0.3135,"mean":0.2323,"median":0.2346,"p25":0.2152,"p50":0.2346,"p75